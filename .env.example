# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here          # https://console.groq.com

# ── Database ──────────────────────────────────────────────────────────────────
# Local / Docker:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sales_db
# Render: set automatically from render.yaml (fromDatabase)

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:
REDIS_URL=redis://localhost:6379
# Production (Render): use Upstash — https://upstash.com (free tier available)
# REDIS_URL=rediss://:password@host.upstash.io:6380

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Production: set to your Vercel URL
# ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Production passwords (docker-compose.prod.yml only) ───────────────────────
POSTGRES_PASSWORD=change_me_in_production
REDIS_PASSWORD=change_me_in_production

# ── Optional ──────────────────────────────────────────────────────────────────
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=your_langsmith_key_here

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Set this in the Vercel dashboard under Settings → Environment Variables.
# Use API_URL (server-only, not exposed to browser) for better security.
# API_URL=https://your-render-service.onrender.com
#
# Or use the public variant if API_URL doesn't work for your setup:
# NEXT_PUBLIC_API_URL=https://your-render-service.onrender.com
